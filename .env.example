APP_BASE_URL=http://localhost:3000

# Chat model keys
LLAMA_API_KEY=your_llama_api_key_here
LLAMA_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin credentials (backend)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Email transport (Nodemailer)
# Primary variables requested for notifications:
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password_or_smtp_password

# Optional SMTP overrides (defaults to Gmail SMTP if omitted)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
FROM_EMAIL=TheraSense <your_email@example.com>